{
  "version": 2,
  "builds": [
    { "src": "server/server.js", "use": "@vercel/node" },
    { "src": "client/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server/server.js" },
    { "src": "/client/(.*)", "dest": "/client/$1" },
    { "src": "/(.*)", "dest": "/server/server.js" }
  ]
}